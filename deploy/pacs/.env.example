# Cloudflare R2 credentials (from R2 API Token)
R2_ACCOUNT_ID=your-account-id-here
R2_ACCESS_KEY_ID=your-access-key-id-here
R2_SECRET_ACCESS_KEY=your-secret-access-key-here
R2_BUCKET_NAME=his-pacs-dicom

# Orthanc admin password (used by HIS backend to authenticate)
# Generate strong: openssl rand -base64 32
ORTHANC_ADMIN_PASSWORD=change-me-to-strong-random-password

# Public domain for PACS (must resolve to Oracle VM public IP)
# Example: pacs.your-domain.com
# If no domain, use VM IP directly (but no HTTPS — not recommended for prod)
PACS_DOMAIN=pacs.your-domain.com
